<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تكبيرات العيد - Takbeer Eid</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(to bottom, #0f172a, #0f1419, #0f172a);
            color: #fef3c7;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 600"><defs><pattern id="pattern" x="0" y="0" width="200" height="200" patternUnits="userSpaceOnUse"><path d="M100,20 L150,50 L150,110 L100,140 L50,110 L50,50 Z" fill="none" stroke="%23d97706" stroke-width="1" opacity="0.1"/><path d="M100,20 L120,35 L120,65 L100,80 L80,65 L80,35 Z" fill="none" stroke="%23d97706" stroke-width="1" opacity="0.15"/></pattern></defs><rect width="1200" height="600" fill="none"/><rect width="1200" height="600" fill="url(%23pattern)"/></svg>');
            background-size: 200px 200px;
            opacity: 0.3;
            pointer-events: none;
            z-index: 0;
        }

        .container {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Header */
        header {
            border-bottom: 1px solid rgba(217, 119, 6, 0.1);
            backdrop-filter: blur(10px);
            background: rgba(15, 23, 42, 0.5);
            padding: 1.5rem 1rem;
        }

        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .logo {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f59e0b, #d97706);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        }

        .header-text h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fef3c7;
        }

        .header-text p {
            font-size: 0.75rem;
            color: rgba(254, 243, 199, 0.6);
        }

        .header-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .btn-share {
            background: transparent;
            border: 1px solid rgba(217, 119, 6, 0.3);
            color: #fbbf24;
            width: 36px;
            height: 36px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            font-size: 1rem;
        }

        .btn-share:hover {
            background: rgba(217, 119, 6, 0.1);
            color: #fcd34d;
        }

        /* Main Content */
        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        /* Audio Player */
        .audio-player {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.8), rgba(15, 20, 40, 0.9));
            backdrop-filter: blur(20px);
            border: 1px solid rgba(217, 119, 6, 0.2);
            border-radius: 24px;
            padding: 2rem;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            margin-bottom: 2rem;
        }

        .player-title {
            text-align: center;
            margin-bottom: 2rem;
        }

        .player-title h2 {
            font-size: 2rem;
            font-weight: 700;
            color: #fef3c7;
            margin-bottom: 0.5rem;
        }

        .player-title p {
            font-size: 0.9rem;
            color: rgba(254, 243, 199, 0.7);
        }

        /* Play Button */
        .play-button-container {
            display: flex;
            justify-content: center;
            margin-bottom: 2rem;
        }

        .play-button-circle {
            position: relative;
            width: 200px;
            height: 200px;
        }

        .circle-outer {
            position: absolute;
            inset: 0;
            border: 2px solid rgba(217, 119, 6, 0.3);
            border-radius: 50%;
        }

        .circle-inner {
            position: absolute;
            inset: 8px;
            border: 1px solid rgba(217, 119, 6, 0.2);
            border-radius: 50%;
        }

        .play-btn {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f59e0b, #d97706);
            border-radius: 50%;
            border: none;
            cursor: pointer;
            font-size: 2rem;
            color: #1f2937;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .play-btn:hover {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
        }

        .play-btn:active {
            transform: scale(0.95);
        }

        /* Progress Bar */
        .progress-section {
            margin-bottom: 1.5rem;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: rgba(217, 119, 6, 0.2);
            border-radius: 3px;
            cursor: pointer;
            margin-bottom: 0.5rem;
            position: relative;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #f59e0b, #d97706);
            border-radius: 3px;
            width: 0%;
            transition: width 0.1s linear;
        }

        .time-display {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: rgba(254, 243, 199, 0.6);
        }

        /* Volume Control */
        .volume-control {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: rgba(30, 41, 59, 0.5);
            border-radius: 12px;
            padding: 1rem;
            border: 1px solid rgba(217, 119, 6, 0.1);
        }

        .volume-icon {
            color: #fbbf24;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .volume-slider {
            flex: 1;
            height: 4px;
            background: rgba(217, 119, 6, 0.2);
            border-radius: 2px;
            cursor: pointer;
            position: relative;
        }

        .volume-fill {
            height: 100%;
            background: linear-gradient(90deg, #f59e0b, #d97706);
            border-radius: 2px;
            width: 100%;
        }

        .volume-percent {
            font-size: 0.75rem;
            color: rgba(254, 243, 199, 0.6);
            min-width: 35px;
            text-align: right;
        }

        /* Info Section */
        .info-section {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.5), rgba(15, 23, 42, 0.5));
            backdrop-filter: blur(10px);
            border: 1px solid rgba(217, 119, 6, 0.1);
            border-radius: 18px;
            padding: 2rem;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .info-item {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .info-item:last-child {
            margin-bottom: 0;
        }

        .info-icon {
            font-size: 1.5rem;
            color: #d97706;
            flex-shrink: 0;
            margin-top: 0.25rem;
        }

        .info-content h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #fef3c7;
            margin-bottom: 0.5rem;
        }

        .info-content p {
            font-size: 0.9rem;
            color: rgba(254, 243, 199, 0.7);
            line-height: 1.6;
        }

        /* Footer */
        footer {
            border-top: 1px solid rgba(217, 119, 6, 0.1);
            backdrop-filter: blur(10px);
            background: rgba(15, 23, 42, 0.5);
            padding: 1.5rem 1rem;
            text-align: center;
            margin-top: auto;
        }

        .footer-text {
            font-size: 0.9rem;
            color: rgba(254, 243, 199, 0.6);
            margin-bottom: 0.5rem;
        }

        .footer-copyright {
            font-size: 0.75rem;
            color: rgba(254, 243, 199, 0.4);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                gap: 1rem;
            }

            .header-buttons {
                width: 100%;
                justify-content: center;
            }

            .player-title h2 {
                font-size: 1.5rem;
            }

            .play-button-circle {
                width: 150px;
                height: 150px;
            }

            .audio-player {
                padding: 1.5rem;
            }

            main {
                padding: 1rem;
            }

            .info-section {
                padding: 1.5rem;
            }
        }

        @media (max-width: 480px) {
            header {
                padding: 1rem;
            }

            .logo {
                width: 40px;
                height: 40px;
                font-size: 1.2rem;
            }

            .header-text h1 {
                font-size: 1.2rem;
            }

            .player-title h2 {
                font-size: 1.3rem;
            }

            .play-button-circle {
                width: 120px;
                height: 120px;
            }

            .play-btn {
                font-size: 1.5rem;
            }

            .volume-control {
                flex-direction: column;
                gap: 0.75rem;
            }

            .volume-slider {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="header-content">
            <div class="header-left">
                <div class="logo">🌙</div>
                <div class="header-text">
                    <h1>تكبيرات العيد</h1>
                    <p>Takbeer Eid</p>
                </div>
            </div>
            <div class="header-buttons">
                <button class="btn-share" title="مشاركة على WhatsApp" onclick="shareWhatsApp()">💬</button>
                <button class="btn-share" title="مشاركة على X" onclick="shareX()">𝕏</button>
                <button class="btn-share" title="مشاركة" onclick="shareGeneral()">📤</button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        <!-- Audio Player -->
        <div class="audio-player">
            <div class="player-title">
                <h2>تكبيرات عيد الأضحى</h2>
                <p>تكبيرات العيد الإسلامية متكررة كصدقة جارية</p>
            </div>

            <!-- Play Button -->
            <div class="play-button-container">
                <div class="play-button-circle">
                    <div class="circle-outer"></div>
                    <div class="circle-inner"></div>
                    <button class="play-btn" id="playBtn" onclick="togglePlay()">▶</button>
                </div>
            </div>

            <!-- Progress Bar -->
            <div class="progress-section">
                <div class="progress-bar" onclick="seekAudio(event)">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
                <div class="time-display">
                    <span id="currentTime">0:00</span>
                    <span id="duration">0:00</span>
                </div>
            </div>

            <!-- Volume Control -->
            <div class="volume-control">
                <span class="volume-icon" id="volumeIcon" onclick="toggleMute()">🔊</span>
                <div class="volume-slider" onclick="setVolume(event)">
                    <div class="volume-fill" id="volumeFill"></div>
                </div>
                <span class="volume-percent" id="volumePercent">100%</span>
            </div>
        </div>

        <!-- Info Section -->
        <div class="info-section">
            <div class="info-item">
                <span class="info-icon">❤️</span>
                <div class="info-content">
                    <h3>صدقة جارية</h3>
                    <p>استمع إلى تكبيرات العيد الإسلامية الأصيلة كصدقة جارية. قال رسول الله صلى الله عليه وسلم: "إذا مات ابن آدم انقطع عمله إلا من ثلاث: صدقة جارية، أو علم ينتفع به، أو ولد صالح يدعو له".</p>
                </div>
            </div>
            
            <div class="info-item">
                <span class="info-icon">ℹ️</span>
                <div class="info-content">
                    <h3>عن التكبيرات</h3>
                    <p>التكبير هو من أعظم شعائر الله في عيد الأضحى والعيد الفطر. يستحب التكبير المطلق في كل وقت، والمقيد في أوقات معينة. هذه التكبيرات تذكرنا بعظمة الله وتوحيده.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <p class="footer-text">جعل الله استماعك لهذه التكبيرات صدقة جارية في ميزان حسناتك</p>
        <p class="footer-copyright">© 2026 تكبيرات العيد - جميع الحقوق محفوظة</p>
    </footer>

    <script>
        let currentVolume = 1;
        let isMuted = false;

        // Format time
        function formatTime(seconds) {
            if (!seconds || isNaN(seconds)) return '0:00';
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        // Toggle play/pause
        function togglePlay() {
            const btn = document.getElementById('playBtn');
            btn.textContent = btn.textContent === '▶' ? '⏸' : '▶';
        }

        // Seek audio
        function seekAudio(event) {
            const bar = event.currentTarget;
            const rect = bar.getBoundingClientRect();
            const percent = (event.clientX - rect.left) / rect.width;
            document.getElementById('progressFill').style.width = (percent * 100) + '%';
        }

        // Toggle mute
        function toggleMute() {
            isMuted = !isMuted;
            const icon = document.getElementById('volumeIcon');
            const percent = document.getElementById('volumePercent');
            if (isMuted) {
                icon.textContent = '🔇';
                percent.textContent = '0%';
                document.getElementById('volumeFill').style.width = '0%';
            } else {
                icon.textContent = '🔊';
                percent.textContent = Math.round(currentVolume * 100) + '%';
                document.getElementById('volumeFill').style.width = (currentVolume * 100) + '%';
            }
        }

        // Set volume
        function setVolume(event) {
            const slider = event.currentTarget;
            const rect = slider.getBoundingClientRect();
            const percent = (event.clientX - rect.left) / rect.width;
            currentVolume = Math.max(0, Math.min(1, percent));
            
            if (currentVolume > 0 && isMuted) {
                isMuted = false;
                document.getElementById('volumeIcon').textContent = '🔊';
            }
            
            document.getElementById('volumeFill').style.width = (currentVolume * 100) + '%';
            document.getElementById('volumePercent').textContent = Math.round(currentVolume * 100) + '%';
        }

        // Share functions
        function shareWhatsApp() {
            const text = 'استمع إلى تكبيرات العيد الإسلامية كصدقة جارية 🌙';
            const url = `https://wa.me/?text=${encodeURIComponent(text + ' ' + window.location.href)}`;
            window.open(url, '_blank');
        }

        function shareX() {
            const text = 'استمع إلى تكبيرات العيد الإسلامية كصدقة جارية #تكبيرات_العيد';
            const url = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(window.location.href)}`;
            window.open(url, '_blank');
        }

        function shareGeneral() {
            if (navigator.share) {
                navigator.share({
                    title: 'تكبيرات العيد',
                    text: 'استمع إلى تكبيرات العيد الإسلامية كصدقة جارية',
                    url: window.location.href,
                }).catch(() => {
                    navigator.clipboard.writeText(window.location.href);
                    alert('تم نسخ الرابط');
                });
            } else {
                navigator.clipboard.writeText(window.location.href);
                alert('تم نسخ الرابط');
            }
        }
    </script>
</body>
</html>
