<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>تكبيرات العيد</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Cairo',sans-serif;
}

body{
    background:
    radial-gradient(circle at top,#1f2937,#0f172a 60%);
    color:white;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
    padding:20px;
}

.bg{
    position:absolute;
    inset:0;
    background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size:40px 40px;
    opacity:.3;
}

.card{
    position:relative;
    width:100%;
    max-width:420px;
    background:rgba(255,255,255,0.05);
    backdrop-filter:blur(14px);
    border:1px solid rgba(255,255,255,0.08);
    border-radius:28px;
    padding:35px 25px;
    text-align:center;
    box-shadow:
    0 0 30px rgba(0,0,0,.4),
    inset 0 0 20px rgba(255,255,255,.03);
}

.icon{
    width:90px;
    height:90px;
    margin:auto;
    margin-bottom:20px;
    border-radius:50%;
    background:linear-gradient(135deg,#22c55e,#16a34a);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:40px;
    box-shadow:0 0 25px rgba(34,197,94,.5);
}

h1{
    font-size:32px;
    margin-bottom:10px;
}

.desc{
    color:#cbd5e1;
    line-height:1.8;
    margin-bottom:25px;
    font-size:15px;
}

.player{
    margin:20px 0;
}

audio{
    width:100%;
    border-radius:20px;
}

.btn{
    width:100%;
    border:none;
    border-radius:18px;
    padding:16px;
    font-size:18px;
    font-weight:700;
    cursor:pointer;
    transition:.3s;
}

.play-btn{
    background:linear-gradient(135deg,#22c55e,#16a34a);
    color:white;
    margin-bottom:15px;
}

.play-btn:hover{
    transform:translateY(-2px);
    box-shadow:0 0 25px rgba(34,197,94,.4);
}

.share-btn{
    background:#1e293b;
    color:white;
    border:1px solid rgba(255,255,255,.08);
}

.share-btn:hover{
    background:#334155;
}

.footer{
    margin-top:25px;
    font-size:13px;
    color:#94a3b8;
    line-height:1.8;
}
</style>
</head>

<body>

<div class="bg"></div>

<div class="card">

    <div class="icon">🕌</div>

    <h1>تكبيرات العيد</h1>

    <p class="desc">
        استمع لتكبيرات العيد بجودة عالية<br>
        وانشر الأجر بإذن الله
    </p>

    <div class="player">
        <audio id="takbirAudio" loop>
            <source src="takbirat.mp3" type="audio/mpeg">
            متصفحك لا يدعم الصوت
        </audio>
    </div>

    <button class="btn play-btn" onclick="playAudio()">
        تشغيل التكبيرات
    </button>

    <button class="btn share-btn" onclick="sharePage()">
        مشاركة الصفحة
    </button>

    <div class="footer">
        صدقة جارية لك ولوالديك ولكل من نشرها بإذن الله
    </div>

</div>

<script>
const audio = document.getElementById("takbirAudio");

function playAudio(){
    audio.play();
}

function sharePage(){

    if(navigator.share){
        navigator.share({
            title:'تكبيرات العيد',
            text:'استمع لتكبيرات العيد',
            url:window.location.href
        });
    }else{
        alert("ميزة المشاركة غير مدعومة في جهازك");
    }
}
</script>

</body>
</html>
